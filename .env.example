# ═══════════════════════════════════════════════════════════════
# LOCAL DEMO STACK — fill these to run completely free
# No Azure subscription needed. No API spend.
# ═══════════════════════════════════════════════════════════════

# Groq free tier — get key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT signing key — any string, minimum 32 chars for HS256 security
JWT_SECRET=local-dev-secret-minimum-32-chars-long-change-this

# MCP server base URL — where the agent looks for the MCP server
MCP_SERVER_URL=http://localhost:8003

# Controls which infrastructure stack is active
DEMO_MODE=true

# ═══════════════════════════════════════════════════════════════
# [PRODUCTION] Azure Stack — fill for production deployment
# Leave blank for local demo — these are NOT needed locally
# ═══════════════════════════════════════════════════════════════

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_SQL_CONNECTION_STRING=
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_BING_SEARCH_KEY=