# ── JWT Authentication ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Database ────────────────────────────────────────────────────────
# Use PostgreSQL in production, SQLite for local dev
DB_URL=postgresql://mcpuser:mcppassword@db:5432/mcpdb
# DB_URL=sqlite:///./data/mcp_local.db

POSTGRES_DB=mcpdb
POSTGRES_USER=mcpuser
POSTGRES_PASSWORD=mcppassword

# ── MCP Server ──────────────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_SERVER_BASE_URL=http://mcp-server:8000

# ── Tool Registry ───────────────────────────────────────────────────
TOOL_REGISTRY_PATH=mcp_server/registry/tool_registry.yaml

# ── Web Search Tool ─────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-key-here

# ── Azure (Deployment) ──────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-mcp-tool-server
AZURE_CONTAINER_APP_NAME=mcp-tool-server
AZURE_REGISTRY_URL=yourregistry.azurecr.io
AZURE_REGISTRY_USERNAME=your-acr-username
AZURE_REGISTRY_PASSWORD=your-acr-password

# ── GitHub Actions CI ───────────────────────────────────────────────
CI_MCP_SERVER_URL=http://localhost:8000