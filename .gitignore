# ─── Secrets — never commit these ───────────────────────────────────────────
.env
*.pem
*.key
*.p12
*.pfx
jwt_secret*

# ─── Runtime database — seed.sql is committed, the generated .db is not ─────
data/enterprise.db
data/enterprise.db-shm
data/enterprise.db-wal

# ─── Python artifacts ────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ─── uv ──────────────────────────────────────────────────────────────────────
.uv/

# ─── OS artifacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE artifacts ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── Test + coverage artifacts ───────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ─── Pre-commit cache ────────────────────────────────────────────────────────
.pre-commit-cache/

# ─── Docker volumes ──────────────────────────────────────────────────────────
docker-volumes/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/